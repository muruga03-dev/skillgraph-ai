PORT=5000
MONGODB_URI=mongodb://localhost:27017/skillgraph
JWT_SECRET=skillgraph_jwt_secret_change_in_production
JWT_EXPIRES_IN=7d
ML_SERVICE_URL=http://localhost:8000
CLIENT_URL=http://localhost:3000

# Google OAuth (get from console.developers.google.com)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# LinkedIn OAuth (get from developer.linkedin.com)
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_CALLBACK_URL=http://localhost:5000/api/auth/linkedin/callback

SESSION_SECRET=skillgraph_session_secret_change_in_production
